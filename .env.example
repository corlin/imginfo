# 项目配置
PROJECT_NAME="图片信息解析系统"
VERSION="1.0.0"
DEBUG=True

# 服务器配置
HOST="0.0.0.0"
PORT=8000

# 数据库配置（默认使用SQLite）
DATABASE_URL="sqlite:///./imginfo.db"

# 文件上传配置
UPLOAD_DIR="uploads"
MAX_FILE_SIZE=10485760  # 10MB in bytes
ALLOWED_EXTENSIONS=["jpg","jpeg","png","bmp","gif","tiff","webp"]
MIN_RESOLUTION=[100,100]
MAX_RESOLUTION=[8192,8192]

# API提供商配置（openai/openrouter/xiaomi_mimo/azure/aliyun/zhipu/custom）
API_PROVIDER="openrouter"

# OpenAI兼容API配置
OPENAI_API_KEY="your_openai_api_key_here"
OPENAI_API_BASE="https://api.openai.com/v1"
OPENAI_VISION_MODEL="gpt-4-vision-preview"
OPENAI_IMAGE_MODEL="dall-e-3"

# OpenRouter配置
OPENROUTER_API_KEY="your_openrouter_api_key_here"
OPENROUTER_API_BASE="https://openrouter.ai/api/v1"
OPENROUTER_VISION_MODEL="openai/gpt-5.4-image-2"
OPENROUTER_IMAGE_MODEL="openai/gpt-5.4-image-2"

# 自定义API配置（当API_PROVIDER=custom或其他第三方时使用）
# 例如小米MIMO: CUSTOM_API_BASE="https://api.xiaomimimo.com/v1"
# 例如阿里云通义: CUSTOM_API_BASE="https://dashscope.aliyuncs.com/compatible-mode/v1"
CUSTOM_API_BASE=""
CUSTOM_API_KEY=""
CUSTOM_VISION_MODEL=""
CUSTOM_IMAGE_MODEL=""

# 图片分析配置
VISION_MAX_TOKENS=4096
VISION_DETAIL="high"

# 文生图配置
IMAGE_SIZE="1024x1024"
IMAGE_QUALITY="standard"
IMAGE_STYLE="natural"
